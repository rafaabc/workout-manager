{
  "name": "gestao-treinos-academia",
  "version": "1.0.0",
  "type": "module",
  "main": "src/app.js",
  "engines": {
    "node": ">=21"
  },
  "scripts": {
    "start": "node src/app.js",
    "server": "cd frontend && http-server",
    "test": "mocha --config ./test/mocha.config.json",
    "test:report": "mocha --config ./test/mocha.config.json --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=index,quiet=true,overwrite=true,html=true,json=false",
    "lint": "eslint . --ext .js --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write src/**/*.js frontend/src/**/*.{js,css,html} test/**/*.js",
    "audit": "npm audit --audit-level=critical",
    "prepare": "husky install",
    "k6:register": "k6 run performance/k6/login/register_user_performance.test.js",
    "k6:register:html": "k6 run --out html=performance/k6/login/register_user_performance.html performance/k6/login/register_user_performance.test.js"
  },
  "dependencies": {
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "chai": "^6.2.2",
    "dotenv": "^17.2.4",
    "eslint": "^10.0.2",
    "eslint-plugin-security": "^1.4.0",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.4",
    "mocha": "^11.1.0",
    "mochawesome": "^7.1.4",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "npm run lint:fix",
      "npm run format",
      "git add"
    ]
  }
}
