# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare text files
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env*  text eol=lf

# Binary files — do not modify line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
