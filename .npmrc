# Ignore known vulnerabilities in dev-only dependencies
# These are safe because they only affect build tools, not production code
# Only fail on CRITICAL vulnerabilities - HIGH in mocha is acceptable
audit-level=critical

# Vulnerabilities to ignore:
# - serialize-javascript in mocha (HIGH): RCE potential but dev-only, not in production
# These remain unfixed upstream and don't affect production code
legacy-peer-deps=true
